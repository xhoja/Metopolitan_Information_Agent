<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_login" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <collaboration id="Collab_login">
    <participant id="part_login" name="Login Process" processRef="proc_login" />
  </collaboration>
  <process id="proc_login" name="Login Process" isExecutable="false">
    <laneSet id="ls_login">
      <lane id="lane_user" name="User (Browser)">
        <flowNodeRef>t_show_error</flowNodeRef>
        <flowNodeRef>ev_start</flowNodeRef>
        <flowNodeRef>t_enter</flowNodeRef>
        <flowNodeRef>t_submit</flowNodeRef>
        <flowNodeRef>ev_end</flowNodeRef>
        <flowNodeRef>t_store</flowNodeRef>
        <flowNodeRef>t_stu</flowNodeRef>
        <flowNodeRef>t_admin</flowNodeRef>
        <flowNodeRef>t_prof</flowNodeRef>
      </lane>
      <lane id="lane_backend" name="Backend">
        <flowNodeRef>t_validate</flowNodeRef>
        <flowNodeRef>gw_valid</flowNodeRef>
        <flowNodeRef>t_verify</flowNodeRef>
        <flowNodeRef>t_jwt</flowNodeRef>
        <flowNodeRef>gw_role</flowNodeRef>
      </lane>
    </laneSet>
    <task id="t_validate" name="Validate Credentials" />
    <exclusiveGateway id="gw_valid" name="Valid?" />
    <task id="t_show_error" name="Show Error Message" />
    <task id="t_verify" name="Verify bcrypt Hash" />
    <task id="t_jwt" name="Generate JWT Token (8hr)" />
    <exclusiveGateway id="gw_role" name="Check Role" />
    <sequenceFlow id="sf1" sourceRef="ev_start" targetRef="t_enter" />
    <sequenceFlow id="sf2" sourceRef="t_enter" targetRef="t_submit" />
    <sequenceFlow id="sf3" sourceRef="t_submit" targetRef="t_validate" />
    <sequenceFlow id="sf4" sourceRef="t_validate" targetRef="gw_valid" />
    <sequenceFlow id="sf5" name="Invalid" sourceRef="gw_valid" targetRef="t_show_error" />
    <sequenceFlow id="sf6" sourceRef="t_show_error" targetRef="t_submit" />
    <sequenceFlow id="sf7" name="Valid" sourceRef="gw_valid" targetRef="t_verify" />
    <sequenceFlow id="sf8" sourceRef="t_verify" targetRef="t_jwt" />
    <sequenceFlow id="sf9" sourceRef="t_jwt" targetRef="gw_role" />
    <sequenceFlow id="sf10" name="admin" sourceRef="gw_role" targetRef="t_admin" />
    <sequenceFlow id="sf11" name="professor" sourceRef="gw_role" targetRef="t_prof" />
    <sequenceFlow id="sf12" name="student" sourceRef="gw_role" targetRef="t_stu" />
    <sequenceFlow id="sf13" sourceRef="t_admin" targetRef="t_store" />
    <sequenceFlow id="sf14" sourceRef="t_prof" targetRef="t_store" />
    <sequenceFlow id="sf15" sourceRef="t_stu" targetRef="t_store" />
    <sequenceFlow id="sf16" sourceRef="t_store" targetRef="ev_end" />
    <startEvent id="ev_start" name="Open Login Page" />
    <task id="t_enter" name="Enter Email and Password">
      <incoming>Flow_0c7qfvo</incoming>
    </task>
    <task id="t_submit" name="Submit Login">
      <incoming>sf6</incoming>
      <outgoing>Flow_0c7qfvo</outgoing>
    </task>
    <sequenceFlow id="Flow_0c7qfvo" sourceRef="t_submit" targetRef="t_enter" />
    <endEvent id="ev_end" name="End" />
    <task id="t_store" name="Store Token + Role in localStorage" />
    <task id="t_stu" name="Redirect: Student Dashboard" />
    <task id="t_admin" name="Redirect: Admin Dashboard" />
    <task id="t_prof" name="Redirect: Professor Dashboard" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_login">
    <bpmndi:BPMNPlane id="BPMNPlane_login" bpmnElement="Collab_login">
      <bpmndi:BPMNShape id="part_login_di" bpmnElement="part_login" isHorizontal="true">
        <dc:Bounds x="130" y="80" width="1950" height="500" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_backend_di" bpmnElement="lane_backend" isHorizontal="true">
        <dc:Bounds x="180" y="390" width="1900" height="190" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_user_di" bpmnElement="lane_user" isHorizontal="true">
        <dc:Bounds x="180" y="80" width="1900" height="310" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_validate_di" bpmnElement="t_validate">
        <dc:Bounds x="680" y="445" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_valid_di" bpmnElement="gw_valid" isMarkerVisible="true">
