        <di:waypoint x="950" y="390" />
        <di:waypoint x="950" y="275" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="916" y="372" width="32" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="870" y="235" />
        <di:waypoint x="640" y="235" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf7_di" bpmnElement="sf7">
