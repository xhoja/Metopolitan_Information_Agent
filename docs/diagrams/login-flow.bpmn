      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_role_di" bpmnElement="gw_role" isMarkerVisible="true">
        <dc:Bounds x="1475" y="460" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1465" y="517" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ev_start_di" bpmnElement="ev_start">
        <dc:Bounds x="232" y="217" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="207" y="260" width="86" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_enter_di" bpmnElement="t_enter">
        <dc:Bounds x="320" y="195" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_submit_di" bpmnElement="t_submit">
        <dc:Bounds x="520" y="195" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ev_end_di" bpmnElement="ev_end">
        <dc:Bounds x="2022" y="217" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2030" y="260" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_store_di" bpmnElement="t_store">
        <dc:Bounds x="1810" y="210" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_stu_di" bpmnElement="t_stu">
        <dc:Bounds x="1570" y="285" width="160" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_admin_di" bpmnElement="t_admin">
        <dc:Bounds x="1570" y="105" width="160" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_prof_di" bpmnElement="t_prof">
        <dc:Bounds x="1570" y="200" width="160" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="268" y="235" />
        <di:waypoint x="320" y="235" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="460" y="235" />
        <di:waypoint x="520" y="235" />
