          <dc:Bounds x="502" y="252" width="66" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_upload_file_prof_di" bpmnElement="t_upload_file_prof">
        <dc:Bounds x="620" y="130" width="160" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_save_assign_di" bpmnElement="t_save_assign">
        <dc:Bounds x="840" y="180" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ev_throw_assign_di" bpmnElement="ev_throw_assign">
        <dc:Bounds x="1042" y="202" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1031" y="166" width="58" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ev_catch_sub_di" bpmnElement="ev_catch_sub">
        <dc:Bounds x="1152" y="202" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1141" y="164.5" width="57" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_open_sub_di" bpmnElement="t_open_sub">
        <dc:Bounds x="1250" y="180" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t_grade_di" bpmnElement="t_grade">
